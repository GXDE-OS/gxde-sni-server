# 此脚本用于在调试时生成安装包，便于在调试机器上轻松部署与卸载。
# 用法: ./build-deb <选项>

# 选项:
#    -b, --binary          仅构建二进制包（也就是跳过源码包）
#    -d, --install-deps    安装构建依赖
#    -c, --clean           仅清理构建产物
#    -h, --help            打印帮助信息

# 路径配置
CUR_SCRIPT_PATH="$0"
CUR_SCRIPT_DIR="$(dirname "$(realpath "$CUR_SCRIPT_PATH")")"
PROJ_ROOT="$CUR_SCRIPT_DIR"

# 参数
BUILD_BIN=true
BUILD_SRC=false
NO_ASSERT_DEPS=false
ACT_CLEANUPS=false

print_help() {
    echo "使用方法: $0 <选项>"
    echo ""
    echo "可用选项:"
    echo "  -b, --binary          仅构建二进制包而不构建源码包（默认行为）"
    echo "  -c, --clean           清理构建产物后退出"
    echo "  -d, --install-deps    安装构建依赖，然后构建二进制包"
    echo "  -h, --help            打印此信息"
    echo ""
    echo "用法示例:"
    echo "  $0 -d                # 安装依赖并构建二进制包"
    echo "  $0 -c                # 清理构建产物"
    exit 0
}

parse_args() {
    while [[ $# -gt 0 ]]; do
        case $1 in
            -b|--binary)
                BUILD_BIN=true; BUILD_SRC=false; shift ;;
            -c|--clean)
                ACT_CLEANUPS=true; shift ;;
            -d|--install-deps)
                NO_ASSERT_DEPS=true; BUILD_BIN=true; BUILD_SRC=false; shift ;;
            -h|--help)
                print_help ;;
            *)
                echo "未知选项: $1"; print_help ;;
        esac
    done
}

is_toolchain_exists() {
    command -v "$1" &> /dev/null
}

check_toolchains() {
    echo "正在检查必要的工具链是否安装，请稍候..."
    local missing_tools=()

    is_toolchain_exists "dpkg-buildpackage" || missing_tools+=("dpkg-dev")
    is_toolchain_exists "cmake"             || missing_tools+=("cmake")

    if [[ ${#missing_tools[@]} -gt 0 ]]; then
        echo "缺少以下必要工具链: ${missing_tools[*]}"
        echo "可以尝试运行 sudo apt install ${missing_tools[*]}"
        exit 1
    fi
    echo "必要工具链检查通过！"
}

auto_install_deps() {
    if [[ "$NO_ASSERT_DEPS" == true ]]; then
        echo "准备安装构建依赖，请稍候..."
        cd "$PROJ_ROOT" || exit 1

        sudo apt install -y build-essential devscripts debhelper cmake pkg-config

        if command -v mk-build-deps &> /dev/null; then
            echo "使用 mk-build-deps 安装依赖..."
            sudo mk-build-deps --install --remove --root-cmd sudo debian/control
        else
            echo "mk-build-deps 不可用，尝试 apt-get build-dep..."
            sudo apt-get build-dep -y .
        fi
        echo "构建依赖安装完成！"
    fi
}

exec_clean() {
    echo "执行清理..."
    cd "$PROJ_ROOT" || exit 1

    rm -rf debian/.debhelper/
    rm -f  debian/files
    rm -f  debian/*.debhelper.log
    rm -f  debian/*.substvars
    rm -f  debian/debhelper-build-stamp
    rm -rf debian/tmp/
    rm -rf obj-*-linux-gnu/

    rm -f "$PROJ_ROOT"/../gxde-sni-server_*.deb
    rm -f "$PROJ_ROOT"/../gxde-sni-server_*.buildinfo
    rm -f "$PROJ_ROOT"/../gxde-sni-server_*.changes

    echo "清理完成！"
}

exec_build() {
    local dpkg_args=("-us" "-uc")

    [[ "$BUILD_SRC" == true ]] && dpkg_args+=("-S")
    [[ "$BUILD_BIN" == true ]] && dpkg_args+=("-b")

    echo "准备构建 DEB 包，DPKG 参数: ${dpkg_args[*]}"
    cd "$PROJ_ROOT" || exit 1

    dpkg-buildpackage "${dpkg_args[@]}"

    echo "恭喜，如果无报错输出则构建已经完成，Deb包应该可以在上级目录中被找到了！"
}

# ===== 主入口 =====
echo "========================================="
echo "  GXDE SNI Server DEB 构建脚本 REL 0.9.0"
echo "========================================="
echo ""

parse_args "$@"

if [[ "$ACT_CLEANUPS" == true ]]; then
    exec_clean
    exit 0
fi

check_toolchains
auto_install_deps
exec_build